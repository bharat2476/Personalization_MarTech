# Copy to .env and fill in values ( .env is gitignored )
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable (client) or legacy anon JWT from Project Settings -> API
SUPABASE_KEY=your_publishable_or_anon_key

# Optional
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# CDP_MATCH_COUNT=8

# MarTech agent (martech_agent.py)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.1

# Run without OpenAI when quota/billing blocked:
# MARTECH_DEMO_MODE=true
